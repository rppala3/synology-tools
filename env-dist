SYNO_HOST="__CHANGE_ME__"
SYNO_PORT=5001             # Synology default HTTPS port
SYNO_USER="__CHANGE_ME__"
SYNO_PASS="__CHANGE_ME__"
SYNO_VERIFY_TLS=false      # Set to true only if pfSense trusts the DSM certificate
SYNO_APP="Core"

ACME_PATH="/conf/acme"
ACME_CERT_DESC="__CHANGE_ME__"
ACME_CERT_FILE="$ACME_PATH/$ACME_CERT_DESC.crt"
ACME_KEY_FILE="$ACME_PATH/$ACME_CERT_DESC.key"
ACME_CA_FILE="$ACME_PATH/$ACME_CERT_DESC.ca"
ACME_AS_DEFAULT=false
